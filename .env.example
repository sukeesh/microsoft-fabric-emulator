# ---------------------------------------------------------------------------
# Copy to .env and fill in.   cp .env.example .env
# ---------------------------------------------------------------------------

# ===== Local mock (docker-compose) =====
# SQL Server requires a strong SA password (8+ chars, upper+lower+digit+symbol)
# or the container silently fails to start.
# Avoid '$' — docker compose interprets it as variable interpolation.
SA_PASSWORD=LocalFabric_123!
SQL_HOST_PORT=1433

# ===== Connector target =====
# Point this at localhost to hit the LOCAL mock, or at the real Fabric endpoint
# to hit the cloud. The connector auto-detects: host == localhost/127.0.0.1
# -> SQL auth (sa); anything else -> Entra ID service-principal token auth.
MS_FABRIC_SQL_CONNECTION_STRING=localhost:1433
# The mock creates a database with this name. Set it to match your real Fabric
# DB name so the exact same queries/connection string work against both.
MS_FABRIC_DB=fabric_mock

# ===== Real Fabric service principal (only used when host != localhost) =====
# Leave blank for local-only use. ROTATE any secret that has been shared.
MS_FABRIC_CLIENT_ID=
MS_FABRIC_TENANT_ID=
MS_FABRIC_CLIENT_SECRET=
